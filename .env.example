# URL pública del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Clave publicable (antes anon key) — nuevo formato sb_publishable_*
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave secreta de service role — nuevo formato sb_secret_*
# Uso exclusivo en server. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# API key de Resend para envío de emails (opcional en Fase 1)
RESEND_API_KEY=

# URL base de la aplicación (para redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
